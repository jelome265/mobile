# Lichess Mobile App Environment Variables

# API Key for accessing the Lichess API
LICHESS_API_KEY=your_api_key_here

# Lichess user token for authentication
LICHESS_USER_TOKEN=your_user_token_here

# Base URL for the Lichess API
LICHESS_API_URL=https://lichess.org/api

# Enable debug mode (true/false)
DEBUG_MODE=false

# Other application-specific variables
# Add more variables as needed.